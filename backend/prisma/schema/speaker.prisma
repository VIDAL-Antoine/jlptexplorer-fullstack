model speakers {
  id               Int                @id @default(autoincrement())
  slug             String             @unique @db.VarChar(100)
  name_english     String             @db.VarChar(100)
  name_japanese    String?            @db.VarChar(100)
  description      String?
  image_url        String?            @db.VarChar(500)
  transcript_lines transcript_lines[]
}
