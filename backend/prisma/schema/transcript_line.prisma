model transcript_lines {
  id                             Int                              @id @default(autoincrement())
  scene_id                       Int
  start_time                     Int?
  speaker_id                     Int?
  japanese_text                  String
  scenes                         scenes                           @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  speakers                       speakers?                        @relation(fields: [speaker_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  transcript_line_grammar_points transcript_line_grammar_points[]
  translations                   transcript_line_translations[]

  @@unique([scene_id, start_time, speaker_id])
}
