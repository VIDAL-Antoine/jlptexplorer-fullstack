model transcript_lines {
  id                             Int                              @id @default(autoincrement())
  scene_id                       Int
  position                       Int
  speaker                        String?                          @db.VarChar(100)
  text                           String
  translation                    String?
  scenes                         scenes                           @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  transcript_line_grammar_points transcript_line_grammar_points[]

  @@unique([scene_id, position])
}
