model clip_grammar_points {
  clip_id          Int
  grammar_point_id Int
  featured_line_id Int?
  clips            clips             @relation(fields: [clip_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "clip_grammar_points_clip_id_clips_id_fk")
  grammar_points   grammar_points    @relation(fields: [grammar_point_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "clip_grammar_points_grammar_point_id_grammar_points_id_fk")
  featured_line    transcript_lines? @relation(fields: [featured_line_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@id([clip_id, grammar_point_id], map: "clip_grammar_points_clip_id_grammar_point_id_pk")
}
