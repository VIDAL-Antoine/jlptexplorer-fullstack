enum source_type {
  game
  anime
  movie
  series
  music
}

model sources {
  id              Int         @id @default(autoincrement())
  title           String      @db.VarChar(255)
  type            source_type
  cover_image_url String?     @db.VarChar(500)
  created_at      DateTime    @default(now()) @db.Timestamp(6)
  japanese_title  String?     @db.VarChar(255)
  slug            String      @unique(map: "sources_slug_unique") @db.VarChar(100)
  scenes          scenes[]
}
