enum jlpt_level {
  N5
  N4
  N3
  N2
  N1
  Other
}

model grammar_points {
  id                             Int                              @id @default(autoincrement())
  slug                           String                           @unique(map: "grammar_points_slug_unique") @db.VarChar(100)
  title                          String                           @db.VarChar(100)
  romaji                         String                           @db.VarChar(100)
  jlpt_level                     jlpt_level
  created_at                     DateTime                         @default(now()) @db.Timestamp(6)
  transcript_line_grammar_points transcript_line_grammar_points[]
  translations                   grammar_point_translations[]
}
