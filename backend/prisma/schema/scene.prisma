model scenes {
  id               Int                @id @default(autoincrement())
  source_id        Int
  youtube_video_id String             @db.VarChar(20)
  start_time       Int
  end_time         Int
  episode_number   Int                @default(1)
  notes            String?
  created_at       DateTime           @default(now()) @db.Timestamp(6)
  transcript_lines transcript_lines[]
  sources          sources            @relation(fields: [source_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "scenes_source_id_sources_id_fk")
}
